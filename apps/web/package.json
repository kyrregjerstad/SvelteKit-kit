{
	"name": "@sveltekit-kit/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"run-setup": "bun scripts/setup.ts",
		"dev": "varlock run -- vp dev",
		"build": "varlock run -- vp build",
		"preview": "varlock run -- vp preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "vp fmt . --write",
		"lint": "vp lint .",
		"test:unit": "vp test run",
		"test": "vp test run && vp run test:e2e",
		"test:e2e": "playwright test",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.18.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.3",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"eslint-plugin-svelte": "^3.19.0",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"layerchart": "^2.0.0-next.65",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.60.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest",
		"vitest-browser-svelte": "^2.1.1",
		"vite-plus": "latest"
	},
	"dependencies": {
		"@sveltekit-kit/db": "workspace:*",
		"@varlock/1password-plugin": "^1.2.0",
		"@varlock/vite-integration": "^1.1.3",
		"better-auth": "^1.6.18",
		"varlock": "^1.6.1"
	}
}
