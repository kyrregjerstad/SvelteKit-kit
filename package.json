{
	"name": "sveltekit-kit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "vp run --filter ./apps/web dev",
		"build": "vp run --filter ./apps/web build",
		"preview": "vp run --filter ./apps/web preview",
		"check": "vp check && vp run --filter ./apps/web check:svelte",
		"format": "vp fmt . --write",
		"lint": "vp lint .",
		"test": "vp run --filter ./apps/web test",
		"test:unit": "vp run --filter ./apps/web test:unit",
		"test:e2e": "vp run --filter ./apps/web test:e2e",
		"db:push": "vp run --filter ./packages/db db:push",
		"db:generate": "vp run --filter ./packages/db db:generate",
		"db:migrate": "vp run --filter ./packages/db db:migrate",
		"db:studio": "vp run --filter ./packages/db db:studio"
	},
	"devDependencies": {
		"eslint-plugin-svelte": "^3.19.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	},
	"packageManager": "bun@1.3.14",
	"overrides": {
		"vite": "npm:@voidzero-dev/vite-plus-core@latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
	}
}
